# Datos crudos — archivos grandes, no versionar
data/raw/
data/static/
*.nc
*.nc4
*.tif
*.tiff
*.hdf
*.h5

# Intermedios del pipeline — reproducibles, no versionar
data/processed/_intermedios/
data/processed/*.parquet
data/processed/_mineria_fire.parquet

# El dataset procesado SÍ se versiona (es el entregable compartido)
!data/processed/patagonia_dataset.csv

# Modelos serializados (pesados)
ia/models/*.joblib
ia/models/*.pkl

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
.venv/
env/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp

# Claude Code — configuración e instrucciones personales (no compartir)
.claude/
CLAUDE.local.md

# macOS / Windows
.DS_Store
Thumbs.db

# Credenciales API — NUNCA commitear
.cdsapirc
.netrc
api_keys.txt
secrets.env
*.key

# model_context
model_context/

# knime — el .knwf y las imágenes de resultados SÍ se versionan
knime/.metadata/
knime/results_knime/.metadata/
